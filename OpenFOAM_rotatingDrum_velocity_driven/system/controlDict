FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pimpleFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         0.5;

deltaT          0.001;

writeControl    timeStep;

writeInterval   1;

runTimeModifiable true;

adjustTimeStep yes;
maxCo 0.5;

functions
{
}
